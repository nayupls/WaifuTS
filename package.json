{
  "name": "changli",
  "version": "0.1.0",
  "description": "A fast, extensible TypeScript computer-use framework built on Effect.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    },
    "./opencode": {
      "types": "./dist/integrations/opencode.d.ts",
      "import": "./dist/integrations/opencode.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "effect": "^3.16.12"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
